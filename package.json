{
  "name": "usesifter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npx concurrently \"npm run dev:server\" \"npm run dev\" \"npm run dev:admin\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:seed": "tsx server/seed.ts",
    "dev:admin": "cd admin && npm run dev",
    "seed:admin": "tsx server/seed-admin.ts",
    "start": "node --import tsx server/index.ts",
    "build:all": "npm run build && cd admin && npm install && npm run build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
