# ── Solana / Blockchain ──────────────────────────────────────────────────────
# Network: "devnet" for testing, "mainnet-beta" for production
VITE_SOLANA_NETWORK=devnet

# RPC endpoint — get a free key at https://helius.dev (faster than public RPC)
# Devnet public fallback: https://api.devnet.solana.com
# Mainnet public fallback: https://api.mainnet-beta.solana.com
VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# USDC mint address (auto-selected by network if left blank)
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
VITE_USDC_MINT=

# Explorer base URL
VITE_EXPLORER_URL=https://solscan.io

# ── Keeper Bot ───────────────────────────────────────────────────────────────
# Solana private key (base58 encoded) — fund with ~0.1 SOL for tx fees
# Generate: solana-keygen new --outfile keeper-wallet.json
# Then export: cat keeper-wallet.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
KEEPER_SOLANA_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
KEEPER_INTERVAL_MS=60000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret

# ── Firebase (Google Sign-In) ─────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
VITE_API_URL=http://localhost:3001